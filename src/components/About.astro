<section id="about" class="py-16 sm:py-24 lg:py-32 bg-navy-900 relative overflow-hidden">
  <!-- Subtle background accent -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-navy-800/50 -skew-x-12 translate-x-1/4"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 sm:gap-16 lg:gap-24 items-center">
      <!-- Left Column -->
      <div>
        <p class="text-navy-300 text-sm font-semibold tracking-[0.2em] uppercase mb-4">
          About JMC Environmental
        </p>
        <h2 class="text-3xl sm:text-4xl xl:text-5xl font-800 text-white tracking-tight leading-tight">
          Two Decades of Environmental Excellence
        </h2>
        <p class="mt-6 text-lg text-white/70 leading-relaxed">
          Founded in 2004, JMC Environmental has been at the forefront of environmental monitoring and compliance in Ireland. We work with quarries, construction firms, industrial facilities, and local authorities to ensure operations meet the highest environmental standards.
        </p>
        <p class="mt-4 text-lg text-white/70 leading-relaxed">
          Our team brings deep expertise in acoustic measurement, air quality analysis, and regulatory compliance &mdash; helping our clients navigate complex environmental requirements with confidence.
        </p>

        <div class="mt-10 grid grid-cols-2 gap-6 sm:gap-8">
          <div>
            <p class="text-3xl font-800 text-white">EPA</p>
            <p class="text-sm text-white/50 mt-1">Licence Compliance</p>
          </div>
          <div>
            <p class="text-3xl font-800 text-white">ISO</p>
            <p class="text-sm text-white/50 mt-1">Certified Standards</p>
          </div>
          <div>
            <p class="text-3xl font-800 text-white">24/7</p>
            <p class="text-sm text-white/50 mt-1">Monitoring Capability</p>
          </div>
          <div>
            <p class="text-3xl font-800 text-white">National</p>
            <p class="text-sm text-white/50 mt-1">Coverage Across Ireland</p>
          </div>
        </div>
      </div>

      <!-- Right Column - Values -->
      <div class="space-y-6 sm:space-y-8">
        <div class="border-l-2 border-navy-500 pl-6 sm:pl-8">
          <h3 class="text-xl font-bold text-white mb-2">Precision</h3>
          <p class="text-white/60 leading-relaxed">
            We use calibrated, industry-leading instrumentation to deliver measurements you can trust and regulators will accept.
          </p>
        </div>
        <div class="border-l-2 border-navy-500 pl-6 sm:pl-8">
          <h3 class="text-xl font-bold text-white mb-2">Experience</h3>
          <p class="text-white/60 leading-relaxed">
            With over 20 years in the field, we've encountered &mdash; and solved &mdash; every environmental compliance challenge there is.
          </p>
        </div>
        <div class="border-l-2 border-navy-500 pl-6 sm:pl-8">
          <h3 class="text-xl font-bold text-white mb-2">Reliability</h3>
          <p class="text-white/60 leading-relaxed">
            Our clients count on us for timely, accurate reporting that keeps their operations running without regulatory disruption.
          </p>
        </div>
        <div class="border-l-2 border-navy-500 pl-6 sm:pl-8">
          <h3 class="text-xl font-bold text-white mb-2">Partnership</h3>
          <p class="text-white/60 leading-relaxed">
            We don't just deliver reports &mdash; we work alongside you as an extension of your team, providing ongoing guidance and support.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
