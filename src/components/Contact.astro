---
---

<section id="contact" class="py-24 lg:py-32 bg-navy-900 relative">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- Left Column - Info -->
      <div>
        <p class="text-navy-300 text-sm font-semibold tracking-[0.2em] uppercase mb-4">
          Get in Touch
        </p>
        <h2 class="text-3xl lg:text-4xl xl:text-5xl font-800 text-white tracking-tight leading-tight">
          Let's Discuss Your Project
        </h2>
        <p class="mt-6 text-lg text-white/60 leading-relaxed">
          Whether you need a one-off noise survey or ongoing environmental monitoring, we're here to help. Get in touch for a free consultation.
        </p>

        <div class="mt-12 space-y-8">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 flex items-center justify-center border border-navy-600 text-navy-300 shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold">Phone</p>
              <a href="tel:+353871234567" class="text-white/50 hover:text-white transition-colors">
                +353 87 123 4567
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 flex items-center justify-center border border-navy-600 text-navy-300 shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold">Email</p>
              <a href="mailto:info@jmcenvironmental.ie" class="text-white/50 hover:text-white transition-colors">
                info@jmcenvironmental.ie
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 flex items-center justify-center border border-navy-600 text-navy-300 shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold">Location</p>
              <p class="text-white/50">Ireland</p>
              <p class="text-white/40 text-sm mt-1">Nationwide service</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column - Form -->
      <div>
        <form class="space-y-6" id="contact-form">
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-white/60 mb-2 uppercase tracking-wide">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-navy-800/50 border border-navy-600 text-white px-4 py-3 focus:outline-none focus:border-navy-400 transition-colors placeholder:text-white/20"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-white/60 mb-2 uppercase tracking-wide">
                Company
              </label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full bg-navy-800/50 border border-navy-600 text-white px-4 py-3 focus:outline-none focus:border-navy-400 transition-colors placeholder:text-white/20"
                placeholder="Company name"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-white/60 mb-2 uppercase tracking-wide">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-navy-800/50 border border-navy-600 text-white px-4 py-3 focus:outline-none focus:border-navy-400 transition-colors placeholder:text-white/20"
              placeholder="your@email.com"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-white/60 mb-2 uppercase tracking-wide">
              Phone
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full bg-navy-800/50 border border-navy-600 text-white px-4 py-3 focus:outline-none focus:border-navy-400 transition-colors placeholder:text-white/20"
              placeholder="+353..."
            />
          </div>

          <div>
            <label for="service" class="block text-sm font-medium text-white/60 mb-2 uppercase tracking-wide">
              Service Required
            </label>
            <select
              id="service"
              name="service"
              class="w-full bg-navy-800/50 border border-navy-600 text-white px-4 py-3 focus:outline-none focus:border-navy-400 transition-colors"
            >
              <option value="" class="bg-navy-900">Select a service...</option>
              <option value="noise" class="bg-navy-900">Noise Monitoring</option>
              <option value="dust" class="bg-navy-900">Dust Monitoring</option>
              <option value="vibration" class="bg-navy-900">Vibration Monitoring</option>
              <option value="compliance" class="bg-navy-900">Environmental Compliance</option>
              <option value="air" class="bg-navy-900">Air Quality</option>
              <option value="equipment" class="bg-navy-900">Equipment Supply</option>
              <option value="consultancy" class="bg-navy-900">Consultancy</option>
              <option value="other" class="bg-navy-900">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-white/60 mb-2 uppercase tracking-wide">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full bg-navy-800/50 border border-navy-600 text-white px-4 py-3 focus:outline-none focus:border-navy-400 transition-colors placeholder:text-white/20 resize-none"
              placeholder="Tell us about your project..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full px-8 py-4 text-sm font-semibold tracking-wide uppercase bg-white text-navy-900 hover:bg-navy-50 transition-colors duration-200"
          >
            Send Enquiry
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
