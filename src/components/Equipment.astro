---
const equipment = [
  {
    category: 'Noise Monitoring',
    items: [
      'Class 1 & Class 2 Sound Level Meters',
      'Unattended Noise Monitoring Stations',
      'Real-Time Noise Loggers with Remote Access',
      'Acoustic Calibrators',
    ],
  },
  {
    category: 'Dust Monitoring',
    items: [
      'Bergerhoff Dust Deposit Gauges',
      'PM10 & PM2.5 Continuous Monitors',
      'High-Volume Air Samplers',
      'Portable Dust Monitors',
    ],
  },
  {
    category: 'Vibration Monitoring',
    items: [
      'Triaxial Vibration Monitors',
      'Continuous Vibration Loggers',
      'Blast Monitoring Equipment',
      'Structural Monitoring Systems',
    ],
  },
  {
    category: 'Weather & Air Quality',
    items: [
      'Automatic Weather Stations',
      'Wind Speed & Direction Sensors',
      'Temperature & Humidity Loggers',
      'Gas Detection Equipment',
    ],
  },
];
---

<section id="equipment" class="py-24 lg:py-32 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section Header -->
    <div class="max-w-2xl mb-16 lg:mb-20">
      <p class="text-navy-500 text-sm font-semibold tracking-[0.2em] uppercase mb-4">
        Equipment & Solutions
      </p>
      <h2 class="text-3xl lg:text-4xl xl:text-5xl font-800 text-navy-900 tracking-tight leading-tight">
        Industry-Leading Monitoring Equipment
      </h2>
      <p class="mt-6 text-lg text-gray-500 leading-relaxed">
        We supply, install, and maintain a comprehensive range of environmental monitoring equipment. All instruments are regularly calibrated to ensure accuracy and regulatory compliance.
      </p>
    </div>

    <!-- Equipment Grid -->
    <div class="grid md:grid-cols-2 gap-8">
      {equipment.map(({ category, items }) => (
        <div class="bg-white p-8 lg:p-10 border border-gray-200 hover:border-navy-200 transition-colors duration-300">
          <h3 class="text-xl font-bold text-navy-900 mb-6 pb-4 border-b border-gray-100">
            {category}
          </h3>
          <ul class="space-y-3">
            {items.map((item) => (
              <li class="flex items-start gap-3 text-gray-600">
                <svg class="w-5 h-5 text-navy-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-16 text-center">
      <p class="text-gray-500 mb-6">
        Need equipment for a specific monitoring requirement? We can advise on the best solution.
      </p>
      <a
        href="#contact"
        class="inline-flex items-center justify-center px-8 py-4 text-sm font-semibold tracking-wide uppercase bg-navy-900 text-white hover:bg-navy-800 transition-colors duration-200"
      >
        Discuss Your Requirements
      </a>
    </div>
  </div>
</section>
