---
import Logo from './Logo.astro';

const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-200">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <Logo color="#0a1628" />
        <p class="mt-6 text-gray-500 leading-relaxed max-w-xs">
          Independent environmental monitoring and compliance specialists serving Ireland for over 20 years.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-base font-bold text-navy-900 mb-5">Services</h4>
        <ul class="space-y-3">
          <li><a href="#services" class="text-gray-500 hover:text-navy-900 transition-colors">Noise Monitoring</a></li>
          <li><a href="#services" class="text-gray-500 hover:text-navy-900 transition-colors">Dust Monitoring</a></li>
          <li><a href="#services" class="text-gray-500 hover:text-navy-900 transition-colors">Vibration Monitoring</a></li>
          <li><a href="#services" class="text-gray-500 hover:text-navy-900 transition-colors">Environmental Compliance</a></li>
          <li><a href="#services" class="text-gray-500 hover:text-navy-900 transition-colors">Air Quality</a></li>
          <li><a href="#services" class="text-gray-500 hover:text-navy-900 transition-colors">Consultancy</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-base font-bold text-navy-900 mb-5">Company</h4>
        <ul class="space-y-3">
          <li><a href="#about" class="text-gray-500 hover:text-navy-900 transition-colors">About Us</a></li>
          <li><a href="#equipment" class="text-gray-500 hover:text-navy-900 transition-colors">Our Capabilities</a></li>
          <li><a href="#contact" class="text-gray-500 hover:text-navy-900 transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-base font-bold text-navy-900 mb-5">Get in Touch</h4>
        <ul class="space-y-4">
          <li>
            <a href="tel:+353871234567" class="flex items-center gap-3 text-gray-500 hover:text-navy-900 transition-colors">
              <svg class="w-5 h-5 text-navy-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              +353 87 123 4567
            </a>
          </li>
          <li>
            <a href="mailto:info@jmcenvironmental.ie" class="flex items-center gap-3 text-gray-500 hover:text-navy-900 transition-colors">
              <svg class="w-5 h-5 text-navy-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              info@jmcenvironmental.ie
            </a>
          </li>
          <li class="flex items-center gap-3 text-gray-500">
            <svg class="w-5 h-5 text-navy-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            Ireland &mdash; Nationwide
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="bg-navy-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-sm text-white/70">
        &copy; {currentYear} JMC Environmental. All rights reserved.
      </p>
      <p class="text-sm text-white/40">
        Independent Environmental Compliance Specialists
      </p>
    </div>
  </div>
</footer>
