---
import Logo from './Logo.astro';

const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'About', href: '#about' },
  { label: 'Equipment', href: '#equipment' },
  { label: 'Contact', href: '#contact' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 lg:h-24">
      <Logo color="white" />

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-10" aria-label="Main navigation">
        {navLinks.map(({ label, href }) => (
          <a
            href={href}
            class="text-sm font-medium tracking-wide uppercase text-white/80 hover:text-white transition-colors duration-200"
          >
            {label}
          </a>
        ))}
        <a
          href="#contact"
          class="ml-2 px-6 py-2.5 text-sm font-semibold tracking-wide uppercase border border-white/30 text-white hover:bg-white hover:text-navy-900 transition-all duration-200"
        >
          Get a Quote
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-white"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-navy-900/98 backdrop-blur-sm border-t border-white/10"
  >
    <nav class="max-w-7xl mx-auto px-6 py-8 flex flex-col gap-6" aria-label="Mobile navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="mobile-nav-link text-lg font-medium tracking-wide uppercase text-white/80 hover:text-white transition-colors"
        >
          {label}
        </a>
      ))}
      <a
        href="#contact"
        class="mobile-nav-link mt-2 px-6 py-3 text-center text-sm font-semibold tracking-wide uppercase border border-white/30 text-white hover:bg-white hover:text-navy-900 transition-all"
      >
        Get a Quote
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const mobileBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const menuIcon = document.getElementById('menu-icon')!;

  // Scroll effect - add background when scrolled
  const updateHeader = () => {
    if (window.scrollY > 50) {
      header.classList.add('bg-navy-900/95', 'backdrop-blur-md', 'shadow-lg');
    } else {
      header.classList.remove('bg-navy-900/95', 'backdrop-blur-md', 'shadow-lg');
    }
  };

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  // Mobile menu toggle
  let isOpen = false;
  mobileBtn.addEventListener('click', () => {
    isOpen = !isOpen;
    mobileMenu.classList.toggle('hidden', !isOpen);
    mobileBtn.setAttribute('aria-expanded', String(isOpen));
    menuIcon.setAttribute(
      'd',
      isOpen
        ? 'M6 18L18 6M6 6l12 12'
        : 'M4 6h16M4 12h16M4 18h16'
    );
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      isOpen = false;
      mobileMenu.classList.add('hidden');
      mobileBtn.setAttribute('aria-expanded', 'false');
      menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    });
  });
</script>
