---
---

<section class="relative min-h-screen flex items-center bg-navy-900 overflow-hidden">
  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-800"></div>

  <!-- Accent line -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-navy-400/30 to-transparent"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-20 sm:pt-32 sm:pb-24 lg:pt-40 lg:pb-24 w-full">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
      <!-- Left Column - Content -->
      <div>
        <!-- Eyebrow -->
        <p class="text-navy-300 text-sm font-semibold tracking-[0.2em] uppercase mb-6 lg:mb-8">
          Est. 2004 &mdash; Environmental Consultancy
        </p>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-5xl xl:text-6xl font-800 text-white leading-[1.05] tracking-tight mb-6 lg:mb-8">
          Environmental<br />
          Compliance,<br />
          <span class="text-navy-300">Delivered.</span>
        </h1>

        <!-- Subline -->
        <p class="text-lg lg:text-xl text-white/60 leading-relaxed max-w-xl mb-10 lg:mb-12">
          Over 20 years of expertise in noise monitoring, dust measurement, and environmental compliance for Ireland's most demanding industries.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="#contact"
            class="inline-flex items-center justify-center px-8 py-4 text-sm font-semibold tracking-wide uppercase bg-white text-navy-900 hover:bg-navy-50 transition-colors duration-200"
          >
            Get in Touch
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="#services"
            class="inline-flex items-center justify-center px-8 py-4 text-sm font-semibold tracking-wide uppercase border border-white/20 text-white hover:border-white/40 transition-colors duration-200"
          >
            Our Services
          </a>
        </div>

        <!-- Stats - hidden on mobile, shown below image on mobile -->
        <div class="hidden lg:grid mt-16 lg:mt-20 pt-10 border-t border-white/10 grid-cols-3 gap-8 max-w-lg">
          <div>
            <p class="text-3xl lg:text-4xl font-800 text-white">20+</p>
            <p class="text-sm text-white/40 mt-1 uppercase tracking-wide">Years</p>
          </div>
          <div>
            <p class="text-3xl lg:text-4xl font-800 text-white">500+</p>
            <p class="text-sm text-white/40 mt-1 uppercase tracking-wide">Projects</p>
          </div>
          <div>
            <p class="text-3xl lg:text-4xl font-800 text-white">100%</p>
            <p class="text-sm text-white/40 mt-1 uppercase tracking-wide">Compliant</p>
          </div>
        </div>
      </div>

      <!-- Right Column - Image -->
      <div class="relative mt-4 lg:mt-16">
        <div class="relative aspect-[4/3] overflow-hidden">
          <img
            src="/hero-quarry.jpg"
            alt="Aerial view of an Irish quarry lake surrounded by forestry at sunset"
            class="w-full h-full object-cover"
            loading="eager"
          />
          <!-- Soft blend into background -->
          <div class="absolute inset-0 bg-gradient-to-l from-transparent via-transparent to-navy-900/30"></div>
        </div>
        <!-- Broken corner frame - prominent, echoing the JMC logo -->
        <div class="absolute -inset-3 pointer-events-none">
          <svg class="w-full h-full" viewBox="0 0 500 380" fill="none" preserveAspectRatio="none">
            <!-- Top line stops short (broken top-right corner) -->
            <path d="M 0 0 L 350 0" stroke="white" stroke-width="2" stroke-opacity="0.7" vector-effect="non-scaling-stroke" />
            <!-- Right line starts lower (the gap) -->
            <path d="M 500 100 L 500 380" stroke="white" stroke-width="2" stroke-opacity="0.7" vector-effect="non-scaling-stroke" />
            <!-- Bottom -->
            <path d="M 500 380 L 0 380" stroke="white" stroke-width="2" stroke-opacity="0.7" vector-effect="non-scaling-stroke" />
            <!-- Left -->
            <path d="M 0 380 L 0 0" stroke="white" stroke-width="2" stroke-opacity="0.7" vector-effect="non-scaling-stroke" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Mobile Stats -->
    <div class="grid lg:hidden grid-cols-3 gap-6 mt-12 pt-8 border-t border-white/10">
      <div>
        <p class="text-2xl sm:text-3xl font-800 text-white">20+</p>
        <p class="text-xs sm:text-sm text-white/40 mt-1 uppercase tracking-wide">Years</p>
      </div>
      <div>
        <p class="text-2xl sm:text-3xl font-800 text-white">500+</p>
        <p class="text-xs sm:text-sm text-white/40 mt-1 uppercase tracking-wide">Projects</p>
      </div>
      <div>
        <p class="text-2xl sm:text-3xl font-800 text-white">100%</p>
        <p class="text-xs sm:text-sm text-white/40 mt-1 uppercase tracking-wide">Compliant</p>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden sm:flex flex-col items-center gap-2 text-white/30">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent"></div>
  </div>
</section>
